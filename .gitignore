release/

# Cargo: keep Cargo.lock for binaries, ignore for libraries.
# This project ships a binary, so Cargo.lock is normally committed. Uncomment
# the next line if you ever convert it to a pure library.
# Cargo.lock

# Backup files generated by `cargo fix`/rustfmt
**/*.rs.bk
*.orig

